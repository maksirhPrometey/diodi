# Docker — скопіюй: cp .env.docker.example .env
# Локально: docker compose up --build
# Production Droplet: bash deploy/docker/deploy.sh

# === PostgreSQL (сервіс db у compose) ===
POSTGRES_USER=diodi
POSTGRES_PASSWORD=ЗМІНИ_НА_СИЛЬНИЙ_ПАРОЛЬ
POSTGRES_DB=diodi
DB_HOST=db
DB_PORT=5432

# === Django ===
SECRET_KEY=згенеруй-python3-c-import-secrets-print-secrets-token_urlsafe-50
DEBUG=False
DJANGO_SETTINGS_MODULE=config.settings.docker

# Домен або IP Droplet
SITE_URL=https://diodi.com.ua
ALLOWED_HOSTS=diodi.com.ua,www.diodi.com.ua,diodi.if.ua,www.diodi.if.ua,64.225.106.4,127.0.0.1,localhost,web
CSRF_TRUSTED_ORIGINS=https://diodi.com.ua,https://www.diodi.com.ua,https://diodi.if.ua,https://www.diodi.if.ua

# До SSL: USE_HTTPS=false, SITE_URL=http://64.225.106.4
# Після certbot: USE_HTTPS=true, SITE_URL=https://diodi.com.ua
USE_HTTPS=false

WEB_CONCURRENCY=2
HTTP_PORT=80

EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=diodi2001@gmail.com

# Google reCAPTCHA v2 (https://www.google.com/recaptcha/admin) — ОБОВ'ЯЗКОВО заповнити перед продакшн-деплоєм
RECAPTCHA_SITE_KEY=
RECAPTCHA_SECRET_KEY=
